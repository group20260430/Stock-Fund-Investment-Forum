# --- Database ---
# Defaults to SQLite for local development.
# For MySQL, uncomment and set:
# DATABASE_URL=mysql+pymysql://forum_user:forum_password@127.0.0.1:3306/stock_fund_forum?charset=utf8mb4
DATABASE_URL=sqlite:///./stock_fund_forum.db

# --- MySQL (only used when DATABASE_URL is not set) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=forum_user
MYSQL_PASSWORD=forum_password
MYSQL_DATABASE=stock_fund_forum

# --- JWT ---
# Access Token: 2 hours  |  Refresh Token: 7 days
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SMTP (Email Verification) ---
# Fill in your SMTP credentials to enable real email sending.
# Leave empty to fall back to console logging (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# --- QQ OAuth ---
# QQ 互联应用配置。真实 APP KEY 请只写入本地 .env，不要提交。
QQ_OAUTH_APP_ID=
QQ_OAUTH_APP_KEY=
QQ_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/qq/callback
FRONTEND_BASE_URL=http://localhost:5173

# --- 管理员初始化账号（开发/测试用）---
ADMIN_PHONE=13800000000
ADMIN_EMAIL=admin@forum.local
ADMIN_PASSWORD=change-me-in-production
ADMIN_NICKNAME=系统管理员
